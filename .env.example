# =============================================================
# Salesforce Automation Pipeline — Environment Configuration
# =============================================================
# Copy this file to .env and fill in your values before running
# setup/validate_setup.js
# =============================================================

# ---------------------------
# OpenAI
# ---------------------------
# Your OpenAI API key (required for transcript analysis)
OPENAI_API_KEY=sk-...

# Model to use for transcript analysis (gpt-4o recommended)
OPENAI_MODEL=gpt-4o

# ---------------------------
# Salesforce (OAuth2 / Connected App)
# ---------------------------
# Salesforce instance URL, e.g. https://yourorg.my.salesforce.com
SALESFORCE_INSTANCE_URL=https://yourorg.my.salesforce.com

# OAuth2 client credentials from your Connected App
SALESFORCE_CLIENT_ID=your_connected_app_consumer_key
SALESFORCE_CLIENT_SECRET=your_connected_app_consumer_secret

# Salesforce user credentials for the integration user
SALESFORCE_USERNAME=integration@yourorg.com
SALESFORCE_PASSWORD=yourpassword
SALESFORCE_SECURITY_TOKEN=yourtoken

# Default Salesforce User ID to own tasks when no assignee is found
SALESFORCE_DEFAULT_OWNER_ID=0050x000000XXXXX

# Salesforce REST API version (default: v59.0)
SALESFORCE_API_VERSION=v59.0

# ---------------------------
# Google Calendar
# ---------------------------
# The Google Calendar ID to monitor for meeting transcripts
# Use "primary" for the primary calendar, or a specific calendar ID
GOOGLE_CALENDAR_ID=primary

# ---------------------------
# Google Sheets
# ---------------------------
# The Spreadsheet ID from the Google Sheets URL
# https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# ---------------------------
# n8n Configuration
# ---------------------------
# Your n8n instance URL (used for webhook URL construction)
N8N_BASE_URL=https://your-n8n-instance.com

# n8n webhook path for manual transcript submissions
N8N_WEBHOOK_PATH=meeting-transcript

# Optional: n8n API key for programmatic workflow management
N8N_API_KEY=your_n8n_api_key
